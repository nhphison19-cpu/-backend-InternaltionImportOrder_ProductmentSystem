// ============================================================
// PRISMA SCHEMA — International Import Order Procurement System
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // đổi thành "mysql" / "sqlserver" nếu cần
  url      = env("DATABASE_URL")
}

// ------------------------- ENUMS -------------------------

enum EmployeeRole {
  ADMIN
  APPROVER
  STAFF
}

enum OrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  CONFIRMED
  IN_TRANSIT
  CUSTOMS_CLEARANCE
  DELIVERED
  CANCELLED
  REJECTED
}

enum PaymentMethod {
  LC // Letter of Credit
  TT // Telegraphic Transfer
  DP // Documents against Payment
  DA // Documents against Acceptance
  CAD // Cash Against Documents
  OA // Open Account
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum ShipmentMode {
  SEA
  AIR
  RAIL
  ROAD
  MULTIMODAL
}

enum ShipmentStatus {
  PENDING
  BOOKED
  DEPARTED
  IN_TRANSIT
  ARRIVED
  DELIVERED
  DELAYED
}

enum Incoterm {
  EXW
  FCA
  FAS
  FOB
  CFR
  CIF
  CPT
  CIP
  DAP
  DPU
  DDP
}

enum DocumentType {
  COMMERCIAL_INVOICE
  PACKING_LIST
  BILL_OF_LADING
  AIRWAY_BILL
  CERTIFICATE_OF_ORIGIN
  CUSTOMS_DECLARATION
  INSURANCE_CERTIFICATE
  INSPECTION_CERTIFICATE
  CONTRACT
  OTHER
}

enum CustomsStatus {
  PENDING
  UNDER_REVIEW
  CLEARED
  HOLD
  REJECTED
}
enum NotificationType {
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_APPROVED
  ORDER_REJECTED
  SHIPMENT_UPDATED
  PAYMENT_RECEIVED
  PAYMENT_OVERDUE
  CUSTOMS_CLEARED
  INVENTORY_LOW
  SYSTEM
}
enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
}
// ------------------------- MASTER DATA -------------------------

model Notification {
  id          String   @id @default(cuid())

  title       String
  message     String

  type        NotificationType
  priority    NotificationPriority @default(MEDIUM)

  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  isRead      Boolean  @default(false)
  readAt      DateTime?

  referenceId String?
  referenceType String?
  url         String?

  createdAt   DateTime @default(now())

  @@index([employeeId])
  @@index([isRead])
  @@index([createdAt])

  @@map("notifications")
}
model Supplier {
  id           String        @id @default(cuid())
  code         String        @unique
  name         String
  country      String
  address      String?
  taxId        String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  bankAccount  String?
  bankName     String?
  swiftCode    String?
  rating       Float?        @default(0)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deleteAt     DateTime?
  products     Product[]
  orders       ImportOrder[]

  @@map("suppliers")
}

model Product {
  id            String      @id @default(cuid())
  sku           String      @unique
  name          String
  description   String?
  hsCode        String? // mã HS phục vụ khai báo hải quan
  unit          String // pcs, kg, box, ...
  originCountry String?
  weightKg      Float? // trọng lượng / đơn vị
  volumeM3      Float? // thể tích / đơn vị
  supplierId    String
  supplier      Supplier    @relation(fields: [supplierId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deleteAt      DateTime?
  isActive      Boolean     @default(true)
  orderItems    OrderItem[]
  inventories   Inventory[]

  @@index([supplierId])
  @@map("products")
}

model Warehouse {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  address  String
  country  String
  isActive Boolean @default(true)

  orders      ImportOrder[]
  inventories Inventory[]

  @@map("warehouses")
}

model Employee {
  id         String       @id @default(cuid())
  name       String
  email      String       @unique
  department String?
  password   String
  role       EmployeeRole @default(STAFF)

  createdOrders  ImportOrder[]  @relation("CreatedBy")
  approvedOrders ImportOrder[]  @relation("ApprovedBy")
  refreshTokens  RefreshToken[]
  notifications Notification[] 
  @@map("employees")
}

// ------------------------- CORE ORDER -------------------------

model ImportOrder {
  id          String @id @default(cuid())
  orderNumber String @unique

  supplierId  String
  supplier    Supplier  @relation(fields: [supplierId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  status   OrderStatus @default(DRAFT)
  incoterm Incoterm

  currency     String // ISO 4217: USD, EUR, JPY...
  exchangeRate Float  @default(1) // tỷ giá quy đổi sang nội tệ

  originPort      String?
  destinationPort String?
  shipmentMode    ShipmentMode?

  orderDate        DateTime  @default(now())
  expectedDelivery DateTime?
  actualDelivery   DateTime?

  subTotal      Float @default(0)
  taxAmount     Float @default(0)
  shippingCost  Float @default(0)
  insuranceCost Float @default(0)
  totalAmount   Float @default(0)

  paymentMethod PaymentMethod?
  paymentStatus PaymentStatus  @default(UNPAID)

  createdById  String
  createdBy    Employee  @relation("CreatedBy", fields: [createdById], references: [id])
  approvedById String?
  approvedBy   Employee? @relation("ApprovedBy", fields: [approvedById], references: [id])

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items               OrderItem[]
  shipments           Shipment[]
  payments            Payment[]
  documents           ImportDocument[]
  customsDeclarations CustomsDeclaration[]

  @@index([supplierId])
  @@index([status])
  @@map("import_orders")
}

model OrderItem {
  id      String      @id @default(cuid())
  orderId String
  order   ImportOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity  Float
  unitPrice Float
  discount  Float @default(0)
  taxRate   Float @default(0)
  lineTotal Float

  receivedQty Float @default(0) // số lượng đã nhận thực tế tại kho

  @@index([orderId])
  @@map("order_items")
}

// ------------------------- LOGISTICS -------------------------

model Shipment {
  id      String      @id @default(cuid())
  orderId String
  order   ImportOrder @relation(fields: [orderId], references: [id])

  trackingNumber  String?
  carrier         String?
  mode            ShipmentMode
  containerNumber String?
  vesselOrFlight  String?
  status          ShipmentStatus @default(PENDING)

  departureDate DateTime?
  arrivalDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@map("shipments")
}

model CustomsDeclaration {
  id      String      @id @default(cuid())
  orderId String
  order   ImportOrder @relation(fields: [orderId], references: [id])

  declarationNo  String        @unique
  declaredValue  Float
  dutyAmount     Float         @default(0)
  vatAmount      Float         @default(0)
  status         CustomsStatus @default(PENDING)
  clearanceDate  DateTime?
  customsOfficer String?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("customs_declarations")
}

// ------------------------- FINANCE -------------------------

model Payment {
  id      String      @id @default(cuid())
  orderId String
  order   ImportOrder @relation(fields: [orderId], references: [id])

  amount      Float
  currency    String
  method      PaymentMethod
  status      PaymentStatus @default(UNPAID)
  referenceNo String?
  paidAt      DateTime?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("payments")
}

// ------------------------- DOCUMENTS -------------------------

model ImportDocument {
  id      String      @id @default(cuid())
  orderId String
  order   ImportOrder @relation(fields: [orderId], references: [id])

  type       DocumentType
  fileUrl    String
  issuedDate DateTime?
  uploadedAt DateTime     @default(now())

  @@index([orderId])
  @@map("import_documents")
}

model RefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  revoked    Boolean  @default(false)
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([employeeId])
  @@map("refresh_tokens")
}

model Inventory {
  id          String   @id @default(cuid())
  warehouseId String
  productId   String
  quantity    Float    @default(0)
  updatedAt   DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([warehouseId, productId])
  @@map("inventories")
}
