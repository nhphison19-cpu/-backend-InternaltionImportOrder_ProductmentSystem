# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL)
# Nếu chạy local: localhost, nếu chạy Docker: db
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

# Authentication
# Hãy tạo một chuỗi ngẫu nhiên (dùng lệnh `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` để tạo)
ACCESS_TOKEN=your_super_secret_access_token_here

# Redis Configuration
# Nếu chạy local: redis://localhost:6379, nếu chạy Docker: redis://redis:6379
REDIS_URL="redis://localhost:6379"

# API Settings (Ví dụ nếu bạn tích hợp thêm service bên thứ 3)
# PAYMENT_GATEWAY_KEY=...